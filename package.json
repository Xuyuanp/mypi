{
  "name": "@pangxuyuan/mypi",
  "version": "0.1.0",
  "description": "Personal pi package containing custom extensions, themes, and prompts",
  "keywords": [
    "pi-package"
  ],
  "author": "pangxuyuan",
  "license": "MIT",
  "pi": {
    "extensions": [
      "./extensions/"
    ],
    "skills": [
      "./skills/"
    ],
    "prompts": [
      "./prompts/"
    ],
    "themes": [
      "./themes/"
    ]
  },
  "scripts": {
    "check": "biome check --fix --no-errors-on-unmatched --error-on-warnings --files-ignore-unknown=true --colors=off"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "^0.67.6",
    "@mariozechner/pi-ai": "^0.67.6",
    "@mariozechner/pi-coding-agent": "^0.67.6",
    "@mariozechner/pi-tui": "^0.67.6",
    "@sinclair/typebox": "*"
  }
}
